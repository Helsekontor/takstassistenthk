<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Takstassistenten – Få tilgang</title>
<style>
  :root { --teal: #1989ac; --teal-dark: #126b89; --bg: #fef4e8; --border: #d9cfc4; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); font-family: 'Segoe UI', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
  .card { background: #fff; border-radius: 16px; border: 1px solid var(--border); padding: 40px; max-width: 460px; width: 100%; box-shadow: 0 4px 24px rgba(0,0,0,0.09); }
  .logo { font-size: 22px; font-weight: 700; color: var(--teal); margin-bottom: 6px; }
  .sub { font-size: 13px; color: #888; margin-bottom: 28px; }
  .pitch { background: #e8f5fa; border-radius: 8px; padding: 14px 16px; font-size: 14px; color: #1a4a5a; line-height: 1.6; margin-bottom: 24px; }
  .pitch strong { display: block; margin-bottom: 6px; font-size: 15px; }
  label { display: block; font-size: 13px; font-weight: 600; color: #333; margin-bottom: 5px; margin-top: 14px; }
  input, select { width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; font-family: inherit; outline: none; transition: border-color 0.15s; }
  input:focus, select:focus { border-color: var(--teal); }
  .name-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  button[type=submit] { width: 100%; margin-top: 22px; padding: 13px; background: var(--teal); color: #fff; border: none; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; transition: background 0.15s; display: flex; align-items: center; justify-content: center; gap: 10px; }
  button[type=submit]:hover { background: var(--teal-dark); }
  button[type=submit]:disabled { opacity: 0.55; cursor: not-allowed; }
  .spinner { display: none; width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.4); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .success { display: none; text-align: center; padding: 20px 0; }
  .success .check { font-size: 48px; margin-bottom: 12px; }
  .success h2 { color: var(--teal); margin-bottom: 8px; }
  .success p { color: #555; font-size: 14px; margin-bottom: 20px; }
  .success a { display: inline-block; background: var(--teal); color: #fff; text-decoration: none; padding: 12px 28px; border-radius: 8px; font-weight: 600; font-size: 15px; }
  .disclaimer { font-size: 11px; color: #aaa; text-align: center; margin-top: 14px; line-height: 1.5; }
</style>
</head>
<body>
<div class="card">
  <div class="logo">⚕ Takstassistenten</div>
  <div class="sub">av Helsekontor Forvaltning AS</div>

  <div class="pitch">
    <strong>🎯 Riktig taksting – hver gang</strong>
    AI-assistent for fastleger og helsesekretærer. Still spørsmål om takster, beskriv en konsultasjon og få komplette takstforslag basert på Normaltariffen.
  </div>

  <div id="form-section">
    <div class="name-row">
      <div>
        <label>Fornavn *</label>
        <input type="text" id="fnavn" placeholder="Kari" required/>
      </div>
      <div>
        <label>Etternavn *</label>
        <input type="text" id="enavn" placeholder="Nordmann" required/>
      </div>
    </div>

    <label>E-post *</label>
    <input type="email" id="epost" placeholder="kari@legekontor.no" required/>

    <label>Legekontor / klinikk *</label>
    <input type="text" id="kontor" placeholder="Eksempel Legesenter AS" required/>

    <label>Rolle *</label>
    <select id="rolle">
      <option value="">Velg rolle...</option>
      <option value="Fastlege">Fastlege</option>
      <option value="Helsesekretær">Helsesekretær</option>
      <option value="Avtalespesialist">Avtalespesialist</option>
      <option value="Sykepleier">Sykepleier</option>
      <option value="Leder/administrasjon">Leder/administrasjon</option>
      <option value="Annet">Annet</option>
    </select>

    <button type="submit" id="submit-btn" onclick="registerUser()">
      <div class="spinner" id="spinner"></div>
      Få gratis tilgang
    </button>
    <div class="disclaimer">Ved å registrere deg godtar du at vi kan kontakte deg mtp. Takstassistenten. Vi deler ikke dine opplysninger.</div>
  </div>

  <div class="success" id="success-section">
    <div class="check">✅</div>
    <h2>Du har fått tilgang!</h2>
    <p>Velkommen til Takstassistenten. Klikk nedenfor for å starte.</p>
    <a href="/index.html">Åpne Takstassistenten →</a>
  </div>
</div>

<script>
// Check if already registered
if (localStorage.getItem('takst_registered')) {
  window.location.href = '/index.html';
}

function registerUser() {
  const fname = document.getElementById('fnavn').value.trim();
  const lname = document.getElementById('enavn').value.trim();
  const email = document.getElementById('epost').value.trim();
  const clinic = document.getElementById('kontor').value.trim();
  const role = document.getElementById('rolle').value;

  if (!fname || !lname || !email || !clinic || !role) {
    alert('Fyll inn alle feltene for å fortsette.');
    return;
  }
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    alert('Ugyldig e-postadresse.');
    return;
  }

  const btn = document.getElementById('submit-btn');
  const spinner = document.getElementById('spinner');
  btn.disabled = true;
  spinner.style.display = 'block';

  const payload = {
    fornavn: fname,
    etternavn: lname,
    epost: email,
    kontor: clinic,
    rolle: role,
    tidspunkt: new Date().toISOString(),
    kilde: window.location.href
  };

  fetch('/api/register', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  })
  .catch(err => console.error('Registrering feil:', err))
  .finally(() => {
    btn.disabled = false;
    spinner.style.display = 'none';
    localStorage.setItem('takst_registered', '1');
    document.getElementById('form-section').style.display = 'none';
    document.getElementById('success-section').style.display = 'block';
  });
}
</script>
</body>
</html>
